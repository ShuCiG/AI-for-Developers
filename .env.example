# Cartesia TTS — register at https://play.cartesia.ai → API Keys
CARTESIA_API_KEY=

# ── Phoenix DB ────────────────────────────────────────────────────────────────
POSTGRES_HOST=phoenix-db
POSTGRES_USER=postgres
POSTGRES_DB=workshop
POSTGRES_PASSWORD=gomanai

PHOENIX_SQL_DATABASE_URL=postgresql://postgres:gomanai@phoenix-db/workshop

